# Caddyfile – ProjectIQ reverse proxy
# Cloudflare Tunnel terminates TLS and forwards plain HTTP to caddy:80,
# so we listen on :80 and match by Host header.

(app) {
    # Route /api/* to backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    # All other traffic goes to the Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Compression
    encode gzip

    # Logging
    log {
        output stdout
        format json
    }
}

(staging-app) {
    # Staging containers are on a separate Docker network.
    # Route via host-mapped ports instead of container names.
    handle /api/* {
        reverse_proxy host.docker.internal:8002
    }

    handle {
        reverse_proxy host.docker.internal:3002
    }

    encode gzip

    log {
        output stdout
        format json
    }
}

http://www.whatiskali.dev, http://whatiskali.dev {
    import app
}

http://staging.whatiskali.dev {
    import staging-app
}

# Local dev fallback (e.g. http://localhost)
:80 {
    import app
}

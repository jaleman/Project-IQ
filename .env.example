# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://projectiq:projectiq_pass@postgres:5432/projectiq
POSTGRES_USER=projectiq
POSTGRES_PASSWORD=projectiq_pass
POSTGRES_DB=projectiq

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Auth ────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Ollama / LLM ────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=gemma4:e4b

# ─── Telegram ─────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your-discord-bot-token

# ─── Microsoft Teams ──────────────────────────────────────────────────────────
TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/your-webhook-url
TEAMS_APP_ID=your-teams-app-id
TEAMS_APP_PASSWORD=your-teams-app-password

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=ProjectIQ

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Create a tunnel in the Cloudflare Zero Trust dashboard:
#   Networks → Tunnels → Create a tunnel → Cloudflared → copy the token.
# Then in Public Hostnames, route your hostname → service: http://caddy:80
# Leave blank to disable the cloudflared service.
CLOUDFLARE_TUNNEL_TOKEN=
